PORT=8080
NODE_ENV=development

# For Supabase/Render deployment prefer DATABASE_URL.
# Example: postgresql://postgres:yourpassword@db.xxxyyyzzz.supabase.co:5432/postgres
# For Render deployment, prefer Supabase Session/Transaction Pooler URL instead of the direct host.
# DATABASE_URL=
DB_SSL=false

DB_HOST=localhost
DB_PORT=5432
DB_USER=skripsi_user
DB_PASSWORD=skripsi_pass
DB_NAME=skripsi_db

JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=7d
